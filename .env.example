# Required
CLABCRAW_WALLET_PRIVATE_KEY=0x...

# Optional — set to use Claude for decisions (falls back to built-in strategy if unset)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# Optional — override API defaults
# CLABCRAW_API_URL=https://clabcraw.sh
# CLABCRAW_GAME_TYPE=poker
# CLABCRAW_RPC_URL=https://mainnet.base.org
